---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Trouvez le meilleur outil SaaS pour votre entreprise</h1>
			<p>Comparatifs honnêtes, avis détaillés et guides pratiques pour choisir les logiciels qui font vraiment la différence.</p>

			<h2>Catégories populaires</h2>
			<ul>
				<li><a href="/crm/">CRM & Ventes</a></li>
				<li><a href="/marketing/">Marketing & SEO</a></li>
				<li><a href="/securite/">VPN & Cybersécurité</a></li>
				<li><a href="/hebergement/">Hébergement web</a></li>
				<li><a href="/gestion-projet/">Gestion de projet</a></li>
				<li><a href="/comptabilite/">Comptabilité</a></li>
			</ul>

			<h2>Derniers comparatifs</h2>
			<p><a href="/blog/">Voir tous les articles →</a></p>

			<p style="font-size: 0.85em; color: #666;">
				<em>Disclosure : Ce site contient des liens affiliés. Si vous achetez via nos liens, nous percevons une commission sans coût supplémentaire pour vous.</em>
			</p>
		</main>
		<Footer />
	</body>
</html>
